ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Database — Supabase Postgres (Settings → Database → Connection string).
# DATABASE_URL: pooled "Transaction" connection (port 6543) for serverless/app queries.
# DIRECT_URL:   direct/"Session" connection (port 5432) for migrations & prisma db push.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Transcription engine: "deepgram" (network, now) or "whisper" (on-device, future)
NEXT_PUBLIC_TRANSCRIPTION_ENGINE=deepgram
# Optional: enables minting short-lived Deepgram keys instead of returning the raw key
DEEPGRAM_PROJECT_ID=

# Supabase — shared layer only (the eventual mycelium cosmos), not the private field.
# The publishable/anon key is safe to expose in the client; guard data with RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
