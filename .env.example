ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
DATABASE_URL="file:./dev.db"
CLAUDE_MODEL=claude-sonnet-4-6
# Transcription engine: "deepgram" (network, now) or "whisper" (on-device, future)
NEXT_PUBLIC_TRANSCRIPTION_ENGINE=deepgram
# Optional: enables minting short-lived Deepgram keys instead of returning the raw key
DEEPGRAM_PROJECT_ID=

# Supabase — shared layer only (the eventual mycelium cosmos), not the private field.
# The publishable/anon key is safe to expose in the client; guard data with RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
