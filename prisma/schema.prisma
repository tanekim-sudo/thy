generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id             String   @id @default(uuid())
  userId         String
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  claudeProcessed Boolean @default(false)
  // Compressed final field state for cross-session palimpsest rendering.
  fieldSnapshot  Json?
  thoughts       Thought[]
  threads        Thread[]

  @@index([userId])
}

model Thought {
  id              String   @id @default(uuid())
  userId          String
  rawText         String
  prosodyJson     String?  // pace, pauses, confidence, trailingOff
  timestamp       DateTime @default(now())
  returnCount     Int      @default(0)
  posX            Float    @default(0)
  posY            Float    @default(0)
  posZ            Float    @default(0)
  velX            Float    @default(0)
  velY            Float    @default(0)
  velZ            Float    @default(0)
  mass            Float    @default(1)
  luminosity      Float    @default(0.5)
  texture         String   @default("smooth") // smooth | rough | very_rough
  state           String   @default("spore") // spore | hypha | fruiting
  charge          Float    @default(0)
  embeddingJson   String?  // Claude-computed vector
  isSynthesis     Boolean  @default(false)
  sourceThoughtIds String? // JSON array
  // Voice-quality derived properties (null for typed input).
  colorTemp        Float?  // 0 = cool blue, 1 = warm amber
  inputVelocity    Float?  // words/sec for the phrase
  inputAcceleration Float? // variance in word timing (smooth vs jerky)
  // Attention / confidence accounting.
  attentionCount  Int      @default(1)
  lastAttendedAt  DateTime @default(now())
  wasAbandoned    Boolean  @default(false)
  // Provenance & modality.
  origin           String  @default("user") // user | ai_expansion | ai_disturb | ai_implicit
  parentFragmentId String?
  contentType      String  @default("type")  // voice | type | sketch
  sketchPath       String? // SVG-ish stroke point data for sketch fragments
  inDraft          Boolean @default(false) // crossed into a shaped page piece
  sessionId       String?
  session         Session? @relation(fields: [sessionId], references: [id])
  threadFragments ThreadFragment[]
  filamentsFrom   Filament[] @relation("FilamentSource")
  filamentsTo     Filament[] @relation("FilamentTarget")

  @@index([userId])
}

model Filament {
  id              String   @id @default(uuid())
  userId          String
  sourceId        String
  targetId        String
  strength        Float    @default(0.1)
  // 18.3 — myelination: 0 = slow visible pulse (~1.5s), 1 = near-instant flash.
  conductionSpeed Float    @default(0.1)
  type            String   @default("resonance") // resonance | tension | echo | temporal
  ageSessions     Int      @default(0)
  isActive        Boolean  @default(true)
  traffic         Int      @default(0)
  source          Thought  @relation("FilamentSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target          Thought  @relation("FilamentTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// User-defined workbench tools (Branch and Reflect ship as builtins).
model Tool {
  id             String   @id @default(uuid())
  userId         String
  instruction    String
  glyphPath      String?  // closed-curve point data for the glyph shape
  mass           Float    @default(0.6)
  opacity        Float    @default(0.6)
  attentionCount Int      @default(1)
  lastUsedAt     DateTime @default(now())
  isBuiltin      Boolean  @default(false)
  builtinKind    String?  // branch | reflect
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

// Traced paths through the field (Part 17.2).
model Thread {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  fragments ThreadFragment[]
  drafts    Draft[]

  @@index([userId])
  @@index([sessionId])
}

model ThreadFragment {
  threadId      String
  fragmentId    String
  sequenceOrder Int
  thread        Thread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fragment      Thought @relation(fields: [fragmentId], references: [id], onDelete: Cascade)

  @@id([threadId, sequenceOrder])
  @@index([fragmentId])
}

// Legibility output — shaped linear text from a thread (Part 17.3).
model Draft {
  id        String   @id @default(uuid())
  threadId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
}

model FieldState {
  id                  String   @id @default(uuid())
  userId              String   @unique
  ontologySignature   String   @default("{}")
  updatedAt           DateTime @updatedAt
}

// Negative space — things approached but not said (abandoned partials).
model NegativeSpace {
  id             String   @id @default(uuid())
  userId         String
  sessionId      String?
  posX           Float
  posY           Float
  partialContent String?
  createdAt      DateTime @default(now())

  @@index([userId])
}

// Long-term per-user learned parameters (populated in a later phase).
model CognitiveSignature {
  userId               String   @id
  avgIncubationSeconds Float?
  circlingPattern      Json?
  disturbTimingOffset  Float?
  updatedAt            DateTime @updatedAt
}

model ClaudeJob {
  id          String   @id @default(uuid())
  userId      String
  type        String   // semantic_memory | temporal | surfacing | identity
  status      String   @default("pending") // pending | running | done | failed
  payload     String
  result      String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId])
}
